ru! defaults.vim mswin.vim
colo 0
se nocp noawa nobk nowb noswf noudf nomore nosol noeol dir= enc=utf-8 vi= cb="*+"
se cf ar hid lz wmnu ru rnu ch=2 ls=2 shm+=at mps+=<:> ww+=<,>,[,] fdl=9 fdm=indent
se hls is sm ic scs ai si et sta sw=2 sts=2 ts=2 ve=block bg=dark sb spr
filetype plugin indent on
let &gp='ag --vimgrep'
let &gfn='Hack NF'
